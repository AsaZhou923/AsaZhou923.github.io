<script>
  import Lenis from "lenis";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const root = document.documentElement;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const coarsePointer = window.matchMedia("(pointer: coarse)").matches;
  const progress = document.querySelector<HTMLElement>("[data-page-progress]");
  const header = document.querySelector<HTMLElement>("[data-site-header]");
  const cursor = document.querySelector<HTMLElement>("[data-cursor-dot]");
  const cursorText = cursor?.querySelector<HTMLElement>("span");
  const cleanups: Array<() => void> = [];

  requestAnimationFrame(() => root.classList.add("is-ready"));

  const savedAura = localStorage.getItem("az-aura") === "ember" ? "ember" : "acid";
  root.dataset.aura = savedAura;

  document.querySelectorAll<HTMLElement>("[data-aura-toggle]").forEach((button) => {
    const updateLabel = () => {
      button.setAttribute("aria-label", root.dataset.aura === "ember" ? "切换为酸性光谱" : "切换为暖色光谱");
    };
    const onClick = () => {
      const next = root.dataset.aura === "ember" ? "acid" : "ember";
      root.dataset.aura = next;
      localStorage.setItem("az-aura", next);
      window.dispatchEvent(new CustomEvent("aura-change", { detail: next }));
      updateLabel();
    };
    updateLabel();
    button.addEventListener("click", onClick);
    cleanups.push(() => button.removeEventListener("click", onClick));
  });

  let lenis: Lenis | undefined;
  if (!reduceMotion && !coarsePointer && document.body.dataset.page !== "article") {
    lenis = new Lenis({
      lerp: 0.075,
      smoothWheel: true,
      wheelMultiplier: 0.9,
      syncTouch: false
    });
    const onTick = (time: number) => lenis?.raf(time * 1000);
    lenis.on("scroll", ScrollTrigger.update);
    gsap.ticker.add(onTick);
    gsap.ticker.lagSmoothing(0);
    cleanups.push(() => {
      gsap.ticker.remove(onTick);
      lenis?.destroy();
    });
  }

  if (!reduceMotion) {
    const context = gsap.context(() => {
      gsap.fromTo(
        "[data-hero-line]",
        { yPercent: 115, rotate: 2 },
        { yPercent: 0, rotate: 0, duration: 1.18, ease: "expo.out", stagger: 0.09, delay: 0.16 }
      );

      gsap.fromTo(
        "[data-hero-fade]",
        { y: 24, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.9, ease: "power3.out", stagger: 0.08, delay: 0.58 }
      );

      gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((element) => {
        gsap.fromTo(
          element,
          { y: 46, opacity: 0, filter: "blur(10px)" },
          {
            y: 0,
            opacity: 1,
            filter: "blur(0px)",
            duration: 0.92,
            ease: "power3.out",
            scrollTrigger: { trigger: element, start: "top 91%", once: true }
          }
        );
      });

      gsap.utils.toArray<HTMLElement>("[data-parallax]").forEach((element) => {
        gsap.to(element, {
          yPercent: Number(element.dataset.parallax ?? -10),
          ease: "none",
          scrollTrigger: {
            trigger: element,
            start: "top bottom",
            end: "bottom top",
            scrub: 1
          }
        });
      });

      const horizontal = document.querySelector<HTMLElement>("[data-horizontal]");
      const track = horizontal?.querySelector<HTMLElement>("[data-horizontal-track]");
      if (horizontal && track && window.innerWidth > 960) {
        const distance = () => Math.max(0, track.scrollWidth - window.innerWidth + 48);
        gsap.to(track, {
          x: () => -distance(),
          ease: "none",
          scrollTrigger: {
            trigger: horizontal,
            pin: true,
            scrub: 0.8,
            anticipatePin: 1,
            invalidateOnRefresh: true,
            end: () => `+=${distance() + window.innerHeight * 0.5}`
          }
        });
      }

      document.querySelectorAll<HTMLElement>("[data-tilt]").forEach((element) => {
        const onMove = (event: PointerEvent) => {
          const rect = element.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - 0.5;
          const y = (event.clientY - rect.top) / rect.height - 0.5;
          gsap.to(element, { rotateY: x * 7, rotateX: y * -6, duration: 0.45, ease: "power2.out" });
          element.style.setProperty("--spot-x", `${event.clientX - rect.left}px`);
          element.style.setProperty("--spot-y", `${event.clientY - rect.top}px`);
        };
        const onLeave = () => gsap.to(element, { rotateY: 0, rotateX: 0, duration: 0.7, ease: "elastic.out(1, .5)" });
        element.addEventListener("pointermove", onMove);
        element.addEventListener("pointerleave", onLeave);
        cleanups.push(() => {
          element.removeEventListener("pointermove", onMove);
          element.removeEventListener("pointerleave", onLeave);
        });
      });
    });
    cleanups.push(() => context.revert());
  }

  const onScroll = () => {
    const scrollable = document.documentElement.scrollHeight - window.innerHeight;
    const amount = scrollable > 0 ? Math.min(1, window.scrollY / scrollable) : 0;
    progress?.style.setProperty("--progress", `${amount}`);
    root.style.setProperty("--page-progress", `${amount}`);
    header?.classList.toggle("is-compact", window.scrollY > 80);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
  cleanups.push(() => window.removeEventListener("scroll", onScroll));

  if (cursor && !coarsePointer && !reduceMotion) {
    const moveX = gsap.quickTo(cursor, "x", { duration: 0.32, ease: "power3" });
    const moveY = gsap.quickTo(cursor, "y", { duration: 0.32, ease: "power3" });
    const onPointerMove = (event: PointerEvent) => {
      moveX(event.clientX);
      moveY(event.clientY);
      cursor.classList.add("is-visible");
      const target = (event.target as HTMLElement).closest<HTMLElement>("a, button, [data-cursor]");
      const label = target?.dataset.cursor ?? (target ? "OPEN" : "");
      cursor.classList.toggle("is-active", Boolean(target));
      if (cursorText) cursorText.textContent = label;
    };
    const onPointerLeave = () => cursor.classList.remove("is-visible");
    window.addEventListener("pointermove", onPointerMove, { passive: true });
    document.documentElement.addEventListener("mouseleave", onPointerLeave);
    cleanups.push(() => {
      window.removeEventListener("pointermove", onPointerMove);
      document.documentElement.removeEventListener("mouseleave", onPointerLeave);
    });
  }

  document.querySelectorAll<HTMLElement>(".article-body pre").forEach((pre) => {
    const code = pre.querySelector("code");
    if (!code || pre.querySelector("button")) return;
    const button = document.createElement("button");
    button.type = "button";
    button.className = "code-copy";
    button.textContent = "COPY";
    button.addEventListener("click", async () => {
      await navigator.clipboard.writeText(code.textContent ?? "");
      button.textContent = "COPIED";
      window.setTimeout(() => { button.textContent = "COPY"; }, 1600);
    });
    pre.append(button);
  });

  let disposed = false;
  const dispose = () => {
    if (disposed) return;
    disposed = true;
    cleanups.forEach((cleanup) => cleanup());
    window.removeEventListener("pagehide", onPageHide);
    window.removeEventListener("pageshow", onPageShow);
  };

  const onPageHide = (event: PageTransitionEvent) => {
    if (event.persisted) {
      lenis?.stop();
      return;
    }
    dispose();
  };

  const onPageShow = (event: PageTransitionEvent) => {
    if (!event.persisted) return;
    lenis?.start();
    onScroll();
    ScrollTrigger.refresh();
  };

  window.addEventListener("pagehide", onPageHide);
  window.addEventListener("pageshow", onPageShow);
</script>
