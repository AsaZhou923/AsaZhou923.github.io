---
import { getCollection } from "astro:content";
import AetherCanvas from "../components/AetherCanvas.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPost = posts[0];
const featuredPosts = posts.slice(0, 3);
const dateLabel = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
}).format(latestPost.data.pubDate);
---

<BaseLayout page="home">
  <main id="main-content">
    <section class="home-hero" aria-labelledby="hero-title">
      <div class="home-hero__index" data-hero-fade>
        <span>INDEX / 00</span>
        <span>PERSONAL SIGNAL</span>
        <span>MMXXVI</span>
      </div>

      <div class="home-hero__scene" data-parallax="-5">
        <AetherCanvas />
      </div>

      <div class="home-hero__title" id="hero-title">
        <span class="title-clip"><span data-hero-line>ASA</span></span>
        <span class="title-clip title-clip--right"><span data-hero-line>ZHOU</span></span>
      </div>

      <div class="home-hero__copy" data-hero-fade>
        <p>Developer · Writer · Digital Gardener</p>
        <h1>把想法做成<br />可以被体验的现实。</h1>
        <span>
          我在这里记录代码、设计、产品和独立创作。
          每一篇文章，都是一次对复杂问题的清晰折射。
        </span>
        <div class="home-hero__actions">
          <a class="action-link action-link--solid" href="/writing/" data-cursor="EXPLORE">
            <span>进入写作档案</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M14 7l5 5-5 5" /></svg>
          </a>
          <a class="action-link" href="/about/" data-cursor="ABOUT">认识我</a>
        </div>
      </div>

      <a class="latest-signal" href={`/posts/${latestPost.id}/`} data-hero-fade data-cursor="READ">
        <span class="latest-signal__light" aria-hidden="true"></span>
        <div>
          <p>Latest transmission · {dateLabel}</p>
          <strong>{latestPost.data.title}</strong>
        </div>
        <svg viewBox="0 0 32 32" aria-hidden="true"><path d="M7 16h18M18 9l7 7-7 7" /></svg>
      </a>

      <div class="home-hero__scroll" data-hero-fade aria-hidden="true">
        <span></span>Scroll to decode
      </div>
    </section>

    <section class="transmission-bar" aria-label="站点实时信息">
      <div class="transmission-bar__track">
        <span><i></i> AVAILABLE FOR IDEAS</span>
        <span>PUBLISHED TO THE OPEN WEB</span>
        <span>{String(posts.length).padStart(2, "0")} PUBLISHED SIGNALS</span>
        <span>ASTRO · REACT · THREE.JS</span>
        <span><i></i> RSS FEED ONLINE</span>
        <span aria-hidden="true"><i></i> AVAILABLE FOR IDEAS</span>
        <span aria-hidden="true">PUBLISHED TO THE OPEN WEB</span>
      </div>
    </section>

    <section class="manifesto" aria-labelledby="manifesto-title">
      <div class="section-marker" data-reveal>
        <span>01</span>
        <p>Manifesto<br />关于这个空间</p>
      </div>
      <div class="manifesto__body">
        <p class="manifesto__lead" id="manifesto-title" data-reveal>
          <span>不是一张静态名片，</span>
          而是一座持续生长的
          <em>液态档案馆。</em>
        </p>
        <div class="manifesto__note" data-reveal>
          <span>THE IDEA</span>
          <p>
            内容值得被认真阅读，也值得被重新发现。这里用电影化的界面承载长期写作，
            用代码制造惊喜，用结构保证每一次访问都不迷路。
          </p>
        </div>
      </div>
    </section>

    <section class="featured" aria-labelledby="featured-title">
      <header class="section-heading" data-reveal>
        <div>
          <span>02 / Selected writing</span>
          <h2 id="featured-title">近期信号</h2>
        </div>
        <p>三篇最近写下的文章。<br />关于构建、思考与让创作持续发生。</p>
      </header>

      <div class="featured-stack">
        {featuredPosts.map((post, index) => (
          <a
            class={`featured-story featured-story--${post.data.accent}`}
            href={`/posts/${post.id}/`}
            data-reveal
            data-tilt
            data-cursor="READ"
          >
            <div class="featured-story__visual" aria-hidden="true">
              <span class="featured-story__halo"></span>
              <span class="featured-story__plane"></span>
              <svg viewBox="0 0 520 400">
                <circle cx="260" cy="200" r="126" />
                <circle cx="260" cy="200" r="68" />
                <path d="M32 200h456M260 0v400" />
                <path d="M74 86 446 314M446 86 74 314" />
              </svg>
              <small>APERTURE / 0{index + 1}</small>
            </div>
            <div class="featured-story__meta">
              <span>0{index + 1}</span>
              <p>{post.data.category} · {post.data.pubDate.toISOString().slice(0, 10)}</p>
              <strong>{post.data.signal}</strong>
            </div>
            <div class="featured-story__copy">
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <ul>
                {post.data.tags.slice(0, 3).map((tag) => <li>{tag}</li>)}
              </ul>
            </div>
            <span class="featured-story__arrow">
              <svg viewBox="0 0 32 32" aria-hidden="true"><path d="M7 16h18M18 9l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="featured__more" data-reveal>
        <p>还有更多内容正在档案里持续生长。</p>
        <a href="/writing/" class="text-link">浏览全部文章 <span>↗</span></a>
      </div>
    </section>

    <section class="project-reel" data-horizontal aria-labelledby="project-title">
      <div class="project-reel__track" data-horizontal-track>
        <article class="project-intro">
          <div class="section-marker">
            <span>03</span>
            <p>Selected lab<br />正在制造</p>
          </div>
          <h2 id="project-title">项目不是展示品，<br /><em>是思想的压力测试。</em></h2>
          <p>向右滚动 / SCROLL TO EXPLORE</p>
        </article>

        {site.projects.map((project) => (
          <a class={`project-panel project-panel--${project.tone}`} href={project.href} data-cursor="OPEN">
            <div class="project-panel__top">
              <span>{project.index}</span>
              <span>{project.eyebrow}</span>
              <i>{project.status}</i>
            </div>
            <div class="project-panel__art" aria-hidden="true">
              <span></span><span></span><span></span>
              <strong>{project.index}</strong>
            </div>
            <div class="project-panel__copy">
              <div>
                <p>{project.description}</p>
                <ul>{project.tags.map((tag) => <li>{tag}</li>)}</ul>
              </div>
              <h3>{project.name}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="principles" aria-labelledby="principles-title">
      <div class="principles__intro" data-reveal>
        <div class="section-marker">
          <span>04</span>
          <p>Operating system<br />创作原则</p>
        </div>
        <h2 id="principles-title">做复杂的事，<br />保持简单的路径。</h2>
      </div>
      <ol>
        {site.principles.map((principle) => (
          <li data-reveal>
            <span>{principle.index}</span>
            <h3>{principle.title}</h3>
            <p>{principle.copy}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="about-teaser" aria-labelledby="about-teaser-title">
      <div class="about-teaser__portrait" data-reveal data-parallax="-8" aria-hidden="true">
        <span class="portrait-ring portrait-ring--one"></span>
        <span class="portrait-ring portrait-ring--two"></span>
        <strong>AZ</strong>
        <small>HUMAN / MAKER / WRITER</small>
      </div>
      <div class="about-teaser__copy" data-reveal>
        <p>05 / About the author</p>
        <h2 id="about-teaser-title">你好，<br />我是 Asa。</h2>
        <span>
          我喜欢把抽象问题变成清晰界面，把零散经验整理成可以复用的文字。
          这个站点是我的工作台、实验室，也是写给未来自己的长期备忘录。
        </span>
        <a class="action-link action-link--light" href="/about/" data-cursor="MEET">
          <span>继续认识我</span>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M14 7l5 5-5 5" /></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
